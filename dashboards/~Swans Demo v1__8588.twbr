      <aliases enabled='yes' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.1mfljnb1l27p021d5ql8i1gf496j].[cnt:collision_id:qk]&quot;' value='Collisions' />
          <alias key='&quot;[federated.1mfljnb1l27p021d5ql8i1gf496j].[sum:Non-Injury Crash (copy)_0352716030160905:qk]&quot;' value='Injuries' />
        </aliases>
      </column>
      <column caption='coordinate filter' datatype='boolean' name='[Calculation_0277122820460544]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='if abs([county_latitude]) = 0 and abs([county_longitude])= 0 &#13;&#10;then FALSE else TRUE end' />
      </column>
      <column caption='Fatality Filter' datatype='boolean' name='[Calculation_0352715961544704]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[number_killed] &gt; 0' />
      </column>
      <column caption='Has Injury' datatype='boolean' name='[Calculation_0352715961651201]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Non-Injury Crash (copy)_0352716030160905] &gt; 0' />
      </column>
      <column caption='Number Fatalities' datatype='integer' name='[Calculation_0352715961860098]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[number_killed]' />
      </column>
      <column caption='Fatality Rate' datatype='real' default-format='p0.0%' name='[Calculation_0352715967946755]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='//Fatality Rate&#13;&#10;SUM([number_killed]) / SUM([number_killed]+ [number_injured])' />
      </column>
      <column caption='Crash Date' datatype='date' name='[Calculation_0352715969740805]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATE([crash_date_time])' />
      </column>
      <column caption='Crash Date Min' datatype='date' name='[Calculation_0352715983552518]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='MIN([Calculation_0352715969740805])' />
      </column>
      <column caption='Non-Injury Crash' datatype='integer' name='[Calculation_0352716005150728]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF (ISNULL([number_injured]) OR [number_injured] = 0)&#13;&#10;AND (ISNULL([number_killed]) OR [number_killed] = 0)&#13;&#10;THEN 1&#13;&#10;ELSE 0&#13;&#10;END' />
      </column>
      <column caption='Injuries per Crash' datatype='real' default-format='n#,##0.0;-#,##0.0' name='[Calculation_0352716031541258]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum([number_injured])/COUNTD([collision_id])' />
      </column>
      <column caption='County Name Null Filter' datatype='boolean' name='[Calculation_1686973616619520]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='NOT ISNULL([county_name])' />
      </column>
      <column caption='Injury Rate' datatype='real' default-format='n#,##0.0;-#,##0.0' name='[Fatality Rate (copy)_0352715968679940]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='//Injury Rate&#13;&#10;SUM([number_injured]) / SUM([number_killed]+ [number_injured])' />
      </column>
      <column caption='Injury Rate 2' datatype='real' default-format='n#,##0.0;-#,##0.0' name='[Injury Rate (copy)_0352716044845068]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='//Injury Rate&#13;&#10;SUM([number_injured]) / SUM([Non-Injury Crash (copy)_0352716030160905])' />
      </column>
      <column caption='Injury Rate 2 (copy)' datatype='real' default-format='n#,##0.0;-#,##0.0' name='[Injury Rate 2 (copy)_0352716061388814]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='//Injury Rate&#13;&#10;SUM([number_injured]) / SUM([Non-Injury Crash (copy)_0352716030160905])' />
      </column>
      <column caption='Injury Crash' datatype='integer' name='[Non-Injury Crash (copy)_0352716030160905]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [number_injured] &gt; 0 OR [number_killed] &gt; 0&#13;&#10;THEN 1&#13;&#10;ELSE 0&#13;&#10;END' />
      </column>
