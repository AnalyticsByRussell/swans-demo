  create  table "swans_demo"."marts"."int_ca_crashes__dbt_tmp"
  
  
    as
  
  (
    

with stg as (

    select
        raw_row_sk,
        collision_id,
        report_number,
        report_version,

        -- safe boolean → integer conversions
        case lower(coalesce(is_preliminary, 'false'))
            when 'true' then 1
            when 'false' then 0
            else null
        end as is_preliminary,

        ncic_code,
        crash_date_time,
        collision_time,
        beat,
        city_id,
        city_code,
        city_name,
        county_code,

        case lower(coalesce(city_is_active, 'false'))
            when 'true' then 1
            when 'false' then 0
            else null
        end as city_is_active,

        case lower(coalesce(city_is_incorporated, 'false'))
            when 'true' then 1
            when 'false' then 0
            else null
        end as city_is_incorporated,

        collision_type_code,
        collision_type_description,
        day_of_week,

        case lower(coalesce(dispatchnotified, 'false'))
            when 'true' then 1
            when 'false' then 0
            else null
        end as dispatchnotified,

        case lower(coalesce(hasphotographs, 'false'))
            when 'true' then 1
            when 'false' then 0
            else null
        end as hasphotographs,

        case lower(coalesce(hitrun, 'false'))
            when 'true' then 1
            when 'false' then 0
            else null
        end as hitrun,

        case lower(coalesce(isdeleted, 'false'))
            when 'true' then 1
            when 'false' then 0
            else null
        end as isdeleted,

        case lower(coalesce(ishighwayrelated, 'false'))
            when 'true' then 1
            when 'false' then 0
            else null
        end as ishighwayrelated,

        case lower(coalesce(istowaway, 'false'))
            when 'true' then 1
            when 'false' then 0
            else null
        end as istowaway,

        judicialdistrict,
        motorvehicleinvolvedwithcode,
        motorvehicleinvolvedwithdesc,
        motorvehicleinvolvedwithotherdesc,

        -- numeric conversions
        try_cast(numberinjured as int) as number_injured,
        try_cast(numberkilled as int) as number_killed,

        weather_1,
        weather_2,
        road_condition_1,
        road_condition_2,
        special_condition,
        lightingcode,
        lightingdescription,
        try_cast(latitude as numeric) as latitude,
        try_cast(longitude as numeric) as longitude

    from "swans_demo"."stg"."stg_ca_crashes"

)

select * from stg
;
  );
  
