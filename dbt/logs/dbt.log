  create  table "swans_demo"."marts"."int_ca_crashes__dbt_tmp"
  
  
    as
  
  (
    with stg as (
    select *
    from "swans_demo"."stg"."stg_ca_crashes"
)

select
    stg.raw_row_sk as raw_row_sk,
    stg.collision_id as collision_id,
    stg.report_number as report_number,
    
    -- Integer
    case when stg.numberinjured ~ '^\d+$' then stg.numberinjured::int else null end as number_injured,
    
    -- Boolean
    case when lower(stg.is_preliminary) = 'true' then true else false end as is_preliminary,
    
    -- Timestamp
    case when stg.crash_date_time is not null then stg.crash_date_time::timestamp else null end as crash_date_time,
    
    -- Numeric
    case when stg.latitude ~ '^-?\d+(\.\d+)?$' then stg.latitude::float else null end as latitude,
    
    -- Text
    stg.city_name as city_name

from stg
  );
  
