  create  table "swans_demo"."marts"."ca_crashes_mart__dbt_tmp"
  
  
    as
  
  (
    -- models/marts/ca_crashes_mart.sql


with base as (

    select *
    from "swans_demo"."marts"."int_ca_crashes"

),

aggregated as (

    select
        county_code,
        county_name,
        county_region,
        county_latitude,
        county_longitude,
        count(*) as total_crashes,
        sum(number_injured) as total_injured,
        sum(number_killed) as total_killed,
        sum(case when hitrun then 1 else 0 end) as hitrun_count,
        sum(unmatched_county_flag) as unmatched_county_count
    from base
    group by
        county_code,
        county_name,
        county_region,
        county_latitude,
        county_longitude
)

select *
from aggregated
  );
  
