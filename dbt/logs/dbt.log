  create  table "swans_demo"."marts"."int_ca_crashes__dbt_tmp"
  
  
    as
  
  (
    -- models/marts/int_ca_crashes.sql


with stg as (
    select *
    from "swans_demo"."stg"."stg_ca_crashes"
)

select
    stg.raw_row_sk,
    stg.collision_id,
    stg.report_number,
    stg.report_version,
    case lower(stg.is_preliminary)
        when 'true' then true
        when 'false' then false
        else null
    end as is_preliminary,
    stg.ncic_code,
    stg.crash_date_time,
    stg.collision_time,
    stg.beat,
    stg.city_id,
    stg.city_code,
    stg.city_name,
    stg.county_code,
    case lower(stg.city_is_active)
        when 'true' then true
        when 'false' then false
        else null
    end as city_is_active,
    case lower(stg.city_is_incorporated)
        when 'true' then true
        when 'false' then false
        else null
    end as city_is_incorporated,
    stg.collision_type_code,
    stg.collision_type_description,
    stg.day_of_week,
    case lower(stg.dispatchnotified)
        when 'true' then true
        when 'false' then false
        else null
    end as dispatchnotified,
    case lower(stg.hasphotographs)
        when 'true' then true
        when 'false' then false
        else null
    end as hasphotographs,
    case lower(stg.hitrun)
        when 'true' then true
        when 'false' then false
        else null
    end as hitrun,
    case lower(stg.isdeleted)
        when 'true' then true
        when 'false' then false
        else null
    end as isdeleted,
    case lower(stg.ishighwayrelated)
        when 'true' then true
        when 'false' then false
        else null
    end as ishighwayrelated,
    case lower(stg.istowaway)
        when 'true' then true
        when 'false' then false
        else null
    end as istowaway,
    stg.judicialdistrict,
    stg.motorvehicleinvolvedwithcode,
    stg.motorvehicleinvolvedwithdesc,
    stg.motorvehicleinvolvedwithotherdesc,
    COALESCE(NULLIF(stg.numberinjured,'')::int,0) AS number_injured,
    COALESCE(NULLIF(stg.numberkilled,'')::int,0) AS number_killed,
    stg.weather_1,
    stg.weather_2,
    stg.road_condition_1,
    stg.road_condition_2,
    stg.special_condition,
    stg.lightingcode,
    stg.lightingdescription,
    COALESCE(NULLIF(stg.latitude,'')::numeric,0) AS latitude,
    COALESCE(NULLIF(stg.longitude,'')::numeric,0) AS longitude
from stg;
  );
  
