  create  table "swans_demo"."marts"."int_ca_crashes__dbt_tmp"
  
  
    as
  
  (
    

with stg as (
    select *
    from "swans_demo"."stg"."stg_ca_crashes"
)

select
    stg.raw_row_sk,
    stg.collision_id,
    stg.report_number,
    stg.report_version,
    
    -- booleans
    case when lower(stg.is_preliminary) = 'true' then true
         when lower(stg.is_preliminary) = 'false' then false
         else null end as is_preliminary,
    case when lower(stg.hasphotographs) = 'true' then true
         when lower(stg.hasphotographs) = 'false' then false
         else null end as has_photographs,
    case when lower(stg.hitrun) = 'true' then true
         when lower(stg.hitrun) = 'false' then false
         else null end as hit_run,
    case when lower(stg.isdeleted) = 'true' then true
         when lower(stg.isdeleted) = 'false' then false
         else null end as is_deleted,
    case when lower(stg.ishighwayrelated) = 'true' then true
         when lower(stg.ishighwayrelated) = 'false' then false
         else null end as is_highway_related,
    case when lower(stg.istowaway) = 'true' then true
         when lower(stg.istowaway) = 'false' then false
         else null end as is_tow_away,
    case when lower(stg.is_county_road) = 'true' then true
         when lower(stg.is_county_road) = 'false' then false
         else null end as is_county_road,
    case when lower(stg.is_free_way) = 'true' then true
         when lower(stg.is_free_way) = 'false' then false
         else null end as is_freeway,

    -- integers
    case when stg.numberinjured ~ '^\d+$' then stg.numberinjured::int else null end as number_injured,
    case when stg.numberkilled ~ '^\d+$' then stg.numberkilled::int else null end as number_killed,
    
    -- timestamps
    case when stg.crash_date_time ~ '^\d{4}-\d{2}-\d{2}' then stg.crash_date_time::timestamp else null end as crash_date_time,
    case when stg.collision_time ~ '^\d{2}:\d{2}(:\d{2})?$' then stg.collision_time::time else null end as collision_time,
    case when stg.createddate ~ '^\d{4}-\d{2}-\d{2}' then stg.createddate::timestamp else null end as created_date,
    case when stg.modifieddate ~ '^\d{4}-\d{2}-\d{2}' then stg.modifieddate::timestamp else null end as modified_date,
    case when stg.notificationdate ~ '^\d{4}-\d{2}-\d{2}' then stg.notificationdate::timestamp else null end as notification_date,

    -- strings / as-is
    stg.beat,
    stg.city_id,
    stg.city_code,
    stg.city_name,
    stg.county_code,
    stg.city_is_active,
    stg.city_is_incorporated,
    stg.collision_type_code,
    stg.collision_type_description,
    stg.day_of_week,
    stg.dispatchnotified,
    stg.judicialdistrict,
    stg.motorvehicleinvolvedwithcode,
    stg.motorvehicleinvolvedwithdesc,
    stg.motorvehicleinvolvedwithotherdesc,
    stg.weather_1,
    stg.weather_2,
    stg.road_condition_1,
    stg.road_condition_2,
    stg.special_condition,
    stg.lightingcode,
    stg.lightingdescription,
    stg.latitude,
    stg.longitude,
    stg.milepostdirection,
    stg.milepostdistance,
    stg.milepostmarker,
    stg.milepostunitofmeasure,
    stg.pedestrianactioncode,
    stg.pedestrianactiondesc,
    stg.primarycollisionfactorcode,
    stg.primarycollisionfactordescription,
    stg.primarycollisionfactoriscited,
    stg.primarycollisionpartynumber,
    stg.primary_rd,
    stg.secondary_rd,
    stg.secondarydirection,
    stg.secondarydistance,
    stg.secondaryunitofmeasure,
    stg.secondaryroad,
    stg.trafficcontroldevicecode,
    stg.chp555version,
    stg.is_additonal_object_struck,
    stg.notificationtimedescription,
    stg.hasdigitalmediafiles,
    stg.evidencenumber,
    stg.islocationrefertonarrative,
    stg.isaioonesameaslocation

from stg
  );
  
