  create  table "swans_demo"."marts"."int_ca_crashes__dbt_tmp"
  
  
    as
  
  (
    

with stg as (
    select *
    from "swans_demo"."stg"."stg_ca_crashes"
)

select
    stg.raw_row_sk,
    stg.collision_id,
    stg.report_number,
    stg.report_version,
    
    case lower(stg.is_preliminary)
        when 'true' then true
        else false
    end as is_preliminary,
    
    stg.ncic_code,
    try_cast(stg.crash_date_time as timestamp) as crash_date_time,
    stg.collision_time,
    stg.beat,
    stg.city_id,
    stg.city_code,
    stg.city_name,
    stg.county_code,
    
    case lower(stg.city_is_active)
        when 'true' then true
        else false
    end as city_is_active,
    
    case lower(stg.city_is_incorporated)
        when 'true' then true
        else false
    end as city_is_incorporated,
    
    stg.collision_type_code,
    stg.collision_type_description,
    stg.day_of_week,
    
    case lower(stg.dispatchnotified)
        when 'true' then true
        else false
    end as dispatch_notified,
    
    case lower(stg.hasphotographs)
        when 'true' then true
        else false
    end as has_photographs,
    
    case lower(stg.hitrun)
        when 'true' then true
        else false
    end as hit_run,
    
    try_cast(stg.numberinjured as int) as number_injured,
    try_cast(stg.numberkilled as int) as number_killed,
    
    stg.weather_1,
    stg.weather_2,
    stg.road_condition_1,
    stg.road_condition_2,
    stg.special_condition,
    stg.lightingcode,
    stg.lightingdescription,
    
    try_cast(stg.latitude as numeric) as latitude,
    try_cast(stg.longitude as numeric) as longitude
    
from stg
  );
  
