        else null
    end as is_freeway,
    stg.chp555version,
    case 
        when lower(stg.isadditonalobjectstruck) = 'true' then true
        when lower(stg.isadditonalobjectstruck) = 'false' then false
        else null
    end as is_additional_object_struck,
    stg.notificationdate,
    stg.notificationtimedescription,
    case 
        when lower(stg.hasdigitalmediafiles) = 'true' then true
        when lower(stg.hasdigitalmediafiles) = 'false' then false
        else null
    end as has_digital_media_files,
    stg.evidencenumber,
    case 
