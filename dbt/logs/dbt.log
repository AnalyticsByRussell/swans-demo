    as
  
  (
    

with stg as (
    select *
    from "swans_demo"."stg"."stg_ca_crashes"
)

select
    stg.raw_row_sk,
    stg.collision_id,
    stg.report_number,
    stg.report_version,
    
    -- Booleans safely cast from text
    case
        when lower(stg.is_preliminary) = 'true' then true
        when lower(stg.is_preliminary) = 'false' then false
        else null
    end as is_preliminary,

    case
        when lower(stg.hasphotographs) = 'true' then true
        when lower(stg.hasphotographs) = 'false' then false
        else null
    end as has_photographs,

