        stg.city_name,
        stg.county_code,
        case lower(stg.city_is_active)
            when 'true' then true
            when 'false' then false
            else null
        end as city_is_active,
        case lower(stg.city_is_incorporated)
            when 'true' then true
            when 'false' then false
            else null
        end as city_is_incorporated,
        stg.collision_type_code,
        stg.collision_type_description,
        stg.day_of_week,
        case lower(stg.dispatchnotified)
            when 'true' then true
            when 'false' then false
            else null
        end as dispatch_notified,
        case lower(stg.hasphotographs)
            when 'true' then true
            when 'false' then false
            else null
        end as has_photographs,
        case lower(stg.hitrun)
            when 'true' then true
            when 'false' then false
            else null
        end as hit_run,
        case lower(stg.isdeleted)
            when 'true' then true
            when 'false' then false
            else null
        end as is_deleted,
        try_cast(stg.number_injured as int) as number_injured,
        try_cast(stg.number_killed as int) as number_killed,
        stg.weather_1,
        stg.weather_2,
        stg.road_condition_1,
        stg.road_condition_2,
        stg.special_condition,
        stg.lighting_code,
        stg.lighting_description,
        try_cast(stg.latitude as double precision) as latitude,
        try_cast(stg.longitude as double precision) as longitude,
        case lower(stg.is_aoi_one_same_as_location)
            when 'true' then true
            when 'false' then false
            else null
        end as is_aoi_one_same_as_location
        -- add any remaining fields here following the same pattern
    from "swans_demo"."stg"."stg_ca_crashes" as stg
)

select * from stg_data
  );
  
