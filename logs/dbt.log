    json_col->>'Crash Date Time'::timestamp as collision_date,
    json_col->>'City Name' as city_name,
    (json_col->>'County Code')::int as county_code,
    json_col->>'PrimaryRoad' as primary_road,
    json_col->>'SecondaryRoad' as secondary_road,
    (json_col->>'NumberKilled')::int as number_killed,
    (json_col->>'NumberInjured')::int as number_injured,
    json_col->>'Collision Type Description' as collision_type,
    json_col->>'Primary Collision Factor Code' as primary_collision_factor,
    json_col->>'LightingCode' as lighting_code,
    json_col->>'RoadwaySurfaceCode' as roadway_surface_code,
    (json_col->>'IsFreeway')::boolean as is_freeway,
    (json_col->>'IsHighwayRelated')::boolean as is_highway_related,
    (json_col->>'IsTowAway')::boolean as is_tow_away,
    (json_col->>'IsCountyRoad')::boolean as is_county_road,
    (json_col->>'NotificationDate')::timestamp as notification_date
from raw_data
  );
  
