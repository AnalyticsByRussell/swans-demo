  create  table "swans_demo"."dbt_temp_fct"."fct_ca_crashes__dbt_tmp"
  
  
    as
  
  (
    -- models/fct/fct_ca_crashes.sql




with stg as (
    select *
    from "swans_demo"."dbt_temp_stg"."stg_ca_crashes"
)

select
    crash_id,
    county_code,
    county_name,
    city_name,
    primary_road,
    collision_type,
    cast(number_killed as integer) as number_killed,
    cast(number_injured as integer) as number_injured,
    crash_datetime::timestamp as crash_datetime
