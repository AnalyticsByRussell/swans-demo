  create  table "swans_demo"."swans_demo"."stg_ca_crashes__dbt_tmp"
  
  
    as
  
  (
    

with raw_data as (
    select
        crash_id,
        raw_json::json as json_col
    from "swans_demo"."raw"."ca_crashes_json_only"
),

parsed as (
    select
        crash_id,
        (json_col->>'_id')::int as crash_num,
        (json_col->>'Collision Date')::timestamp as collision_date,
        json_col->>'County Name' as county,
        json_col->>'PrimaryRoad' as primary_road,
        json_col->>'SecondaryRoad' as secondary_road,
        (json_col->>'NumberKilled')::int as number_killed,
        (json_col->>'NumberInjured')::int as number_injured
    from raw_data
)

select * from parsed
  );
  
